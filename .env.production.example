# Production Environment Configuration
# Copy this file to .env.local and fill in your actual production values

# Firebase Configuration - Production
# Get these values from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_production_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-production-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-production-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-production-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_production_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_production_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_production_measurement_id
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-production-project-id-default-rtdb.firebaseio.com

# Production Settings
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_ENABLE_FIREBASE_TEST_PAGE=false

# Security Settings
NEXT_PUBLIC_ENFORCE_HTTPS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Database Settings
NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=
NEXT_PUBLIC_FIREBASE_EMULATOR_PORT=

# Feature Flags - All enabled in production
NEXT_PUBLIC_USE_PRODUCTION_AUTH=true
NEXT_PUBLIC_USE_PRODUCTION_FEED=true
NEXT_PUBLIC_USE_PRODUCTION_DARES=true
NEXT_PUBLIC_USE_PRODUCTION_TRUTH=true
NEXT_PUBLIC_USE_PRODUCTION_USERS=true
NEXT_PUBLIC_USE_PRODUCTION_FRIENDS=true
NEXT_PUBLIC_USE_PRODUCTION_MESSAGING=true
NEXT_PUBLIC_USE_PRODUCTION_PRESENCE=true
NEXT_PUBLIC_USE_PRODUCTION_MODERATION=true
NEXT_PUBLIC_USE_PRODUCTION_ALERTS=true

# Logging and Monitoring
NEXT_PUBLIC_LOG_LEVEL=error
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://your-production-project.firebaseapp.com
NEXT_PUBLIC_API_TIMEOUT=30000

# Content Security
NEXT_PUBLIC_MAX_FILE_SIZE=10485760  # 10MB
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,video/webm

# Rate Limiting
NEXT_PUBLIC_RATE_LIMIT_REQUESTS=100
NEXT_PUBLIC_RATE_LIMIT_WINDOW=900000  # 15 minutes

# ─── SERVER-SIDE SECRETS (DO NOT EXPOSE TO CLIENT) ───────────────────
# Firebase Admin SDK: full service-account JSON as a single-line string.
# Generate from GCP console → IAM → Service Accounts → "firebase-adminsdk"
# → Keys → Add key → JSON. Paste the entire JSON below (or set via
# `vercel env add FIREBASE_SERVICE_ACCOUNT_JSON production`).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Upstash Redis REST (free tier is sufficient for this app).
# https://console.upstash.com → Create database → Details → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (bot challenge). Optional.
# https://dash.cloudflare.com → Turnstile → Add site.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Set to "true" in production to REQUIRE a Turnstile token on sensitive
# endpoints (signup, report, post create, etc.). Leave unset in dev.
BOT_CHECK_STRICT=false

# Cache Settings
NEXT_PUBLIC_CACHE_TTL=3600  # 1 hour
NEXT_PUBLIC_ENABLE_CACHE=true

# ─── AI CONTENT MODERATION (OpenAI) ───────────────────────────────
# Optional: Enable AI-powered content moderation using OpenAI Moderation API
# Get your API key from https://platform.openai.com/api-keys
# If not set, the app will fall back to rule-based moderation
OPENAI_API_KEY=
NEXT_PUBLIC_USE_OPENAI_MODERATION=false

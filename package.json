{
  "name": "dare-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:production": "next build",
    "start": "next start",
    "start:development": "next start",
    "start:production": "next start",
    "restart:production": "pm2 restart dare-app || npm run start:production",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out",
    "migrate:friendships:dry-run": "node scripts/backfill-friendships.js --dry-run",
    "migrate:friendships": "node scripts/backfill-friendships.js --apply",
    "deploy:production": "npm run build:production && npm run restart:production",
    "deploy:vercel": "vercel --prod",
    "security:audit": "npm audit",
    "security:audit:fix": "npm audit fix",
    "security:audit:production": "npm audit --production"
  },
  "dependencies": {
    "@firebase/auth": "^1.12.1",
    "@firebase/database": "^1.1.1",
    "@firebase/firestore": "^4.12.0",
    "@firebase/storage": "^0.14.1",
    "@types/dompurify": "^3.0.5",
    "@upstash/redis": "^1.37.0",
    "dompurify": "^3.4.1",
    "firebase": "^11.10.0",
    "firebase-admin": "^12.7.0",
    "lucide-react": "^0.575.0",
    "next": "^16.2.4",
    "react": "^19.2.6",
    "react-dom": "19.2.6",
    "server-only": "^0.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
